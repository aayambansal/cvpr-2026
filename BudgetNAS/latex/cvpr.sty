% cvpr.sty - Style file for CVPR / CVPR Workshop papers
% Based on IEEE conference format with CVPR-specific modifications

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cvpr}[2025/01/01 CVPR style]

\RequirePackage{times}
\RequirePackage{epsfig}
\RequirePackage{graphicx}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{booktabs}

% Page layout for CVPR (letter paper, two-column)
\setlength{\textheight}{8.875in}
\setlength{\textwidth}{6.875in}
\setlength{\columnsep}{0.3125in}
\setlength{\topmargin}{0in}
\setlength{\headheight}{0in}
\setlength{\headsep}{0in}
\setlength{\parindent}{1pc}
\setlength{\oddsidemargin}{-.304in}
\setlength{\evensidemargin}{-.304in}

% Title formatting
\def\cvprPaperID#1{\gdef\@cvprPaperID{#1}}
\cvprPaperID{****}

% Section formatting
\renewcommand\section{\@startsection {section}{1}{\z@}%
    {-10pt \@plus -2pt \@minus -2pt}%
    {4pt \@plus 2pt}%
    {\normalfont\large\bfseries}}

\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
    {-8pt \@plus -2pt \@minus -2pt}%
    {4pt \@plus 2pt}%
    {\normalfont\normalsize\bfseries}}

\renewcommand\subsubsection{\@startsection{subsubsection}{3}{\z@}%
    {-6pt \@plus -1pt \@minus -1pt}%
    {2pt \@plus 1pt}%
    {\normalfont\normalsize\bfseries}}

% Abstract formatting
\renewenvironment{abstract}%
    {\centerline{\large\bfseries Abstract}%
    \vspace{-0.5em}\begin{quote}\small}%
    {\par\end{quote}\vskip 1em}

% Page numbering
\pagestyle{empty}

% Hyper-references
\newcommand{\figref}[1]{Fig.~\ref{#1}}
\newcommand{\tabref}[1]{Table~\ref{#1}}
\newcommand{\secref}[1]{Sec.~\ref{#1}}
\newcommand{\eqnref}[1]{Eq.~(\ref{#1})}

\endinput
